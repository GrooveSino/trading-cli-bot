# Shared local service credentials.
# Copy to trading-cli-bot/.env and keep that file out of git.
#
# Recommended exchange-side permissions:
# - Tokyo marketdata collector keys should be read-only/public-data oriented when possible.
# - OKX live keys should enable only the spot/swap trading permissions needed for guarded smoke tests.
# - OKX sim keys must be created for OKX demo trading and kept separate from live keys.
# - Disable withdrawal permission for all service keys.
# - Add IP whitelist where the exchange supports it.

# Binance
# Current CLI does not use Binance private account features. Binance public REST/WS data is used without these keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX live
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

# OKX simulation / demo trading
# These are separate from OKX live keys. ccxt sandbox mode sends x-simulated-trading: 1.
OKX_SIM_API_KEY=
OKX_SIM_API_SECRET=
OKX_SIM_PASSWORD=

# Gate live
# Private access is intentionally disabled. Keep these blank unless a future live enablement pass needs them.
GATE_API_KEY=
GATE_API_SECRET=
GATE_PASSWORD=

# MEXC
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_PASSWORD=

# Hosted MarketData Gateway security
# local-only for localhost development; auth-enabled for any public/network deployment.
MARKETDATA_GATEWAY_SECURITY_MODE=local-only
MARKETDATA_GATEWAY_CORS_ORIGINS=

# Server-side token registry. Store SHA-256 hashes, never raw tokens.
# Format: token_id,sha256_hex,scope1|scope2,expires_at_iso,rate_limit_per_minute
MARKETDATA_GATEWAY_AUTH_TOKEN_HASHES=
MARKETDATA_GATEWAY_AUTH_TOKENS_FILE=
MARKETDATA_GATEWAY_SECRET_PROVIDER=env

# Trading CLI Bot private HTTP snapshot token.
# Must match on the Tokyo host and the local machine when using Tailscale HTTP.
TBOT_MARKETDATA_TOKEN=
